<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <!-- Official NuGet.org feed -->
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />

    <!-- GitHub Packages for Maliev.Aspire.ServiceDefaults -->
    <!-- Credentials should be provided via environment variables or user secrets -->
    <!-- For local development: Add credentials to %APPDATA%\NuGet\NuGet.Config -->
    <!-- For Docker builds: Use BuildKit secrets -->
    <add key="github-maliev" value="https://nuget.pkg.github.com/MALIEV-Co-Ltd/index.json" />
  </packageSources>

  <packageSourceCredentials>
    <github-maliev>
      <!-- Placeholder - replace with actual credentials or use environment variables -->
      <!-- Username: GITHUB_USERNAME environment variable or use actual username -->
      <!-- Password: GITHUB_TOKEN environment variable (Personal Access Token with read:packages scope) -->
      <add key="Username" value="%GITHUB_USERNAME%" />
      <add key="ClearTextPassword" value="%GITHUB_TOKEN%" />
    </github-maliev>
  </packageSourceCredentials>

  <config>
    <add key="globalPackagesFolder" value="packages" />
  </config>
</configuration>
